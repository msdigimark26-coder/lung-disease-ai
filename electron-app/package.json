{
  "name": "lung-ai-desktop",
  "version": "1.0.0",
  "description": "Desktop Application for LungAI Medical AI Platform",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "author": "LungAI Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "electron-is-dev": "^3.0.1"
  },
  "build": {
    "appId": "com.lungai.desktop",
    "productName": "LungAI",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.medical",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
